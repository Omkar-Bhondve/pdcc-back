# ============================================
# SERVER CONFIGURATION
# ============================================
# NODE_ENV=production
NODE_ENV=development
BASE_URL=http://localhost:5000
PORT=5000
ENABLE_CLUSTER=false
WORKERS=4
WORKER_50=false
# BASE_URL=https://iwms.thecanatech.com

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iwms_pdcc_db_sit
DB_USER=postgres
DB_PASSWORD=root
DB_SSL=false

# ============================================
# SECURITY CONFIGURATION
# ============================================
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters-long-change-in-production
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================
# RATE LIMITING
# ============================================
ENABLE_RATE_LIMIT=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
ENABLE_LOGGER=true
ENABLE_FILE_LOGGING=true
LOG_DIR=./logs

# ============================================
# SECURITY FEATURES
# ============================================
ENABLE_CSRF=true
ENABLE_SECURITY_MW=true
# ============================================
# DATABASE MONITORING
# ============================================
ENABLE_SLOW_QUERY_LOG=true
ENABLE_API_TRACKING=true


